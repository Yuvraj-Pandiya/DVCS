# ═════════════════════════════════════════════════════════════════
# DVCS Platform — Environment Variables
# ═════════════════════════════════════════════════════════════════
# Copy this file to `.env` and customize values for your environment.
# All variables have sensible defaults for local development.

# ─────────────────────────────────────────────────────────────────
# PostgreSQL Configuration
# ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dvcs
POSTGRES_USER=dvcs
POSTGRES_PASSWORD=dvcs

# ─────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────
# MinIO / S3 Configuration
# ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=dvcs-objects

# ─────────────────────────────────────────────────────────────────
# Storage Backend Configuration
# ─────────────────────────────────────────────────────────────────
# Options: "local" (filesystem) or "s3" (MinIO/S3)
STORAGE_BACKEND=s3

# Local filesystem storage root (used when STORAGE_BACKEND=local)
STORAGE_ROOT=/data/objects

# ─────────────────────────────────────────────────────────────────
# JWT Authentication Configuration
# ─────────────────────────────────────────────────────────────────
# CRITICAL: Change JWT_SECRET in production to a long random string
# Generate with: openssl rand -base64 64
JWT_SECRET=changeme-in-production-use-a-long-random-string

# Access token expiry in seconds (default: 900 = 15 minutes)
JWT_EXPIRY_SECONDS=900

# Refresh token expiry in days (default: 30 days)
REFRESH_TOKEN_EXPIRY_DAYS=30

# ─────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://dvcs.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
