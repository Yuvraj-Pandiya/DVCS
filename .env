# ═════════════════════════════════════════════════════════════════
# DVCS Platform — Environment Variables
# ═════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# PostgreSQL Configuration
# ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dvcs
POSTGRES_USER=dvcs
POSTGRES_PASSWORD=dvcs

# ─────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────
# MinIO / S3 Configuration
# ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_BUCKET=dvcs-objects
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ─────────────────────────────────────────────────────────────────
# Storage Backend Configuration
# ─────────────────────────────────────────────────────────────────
# Options: "local" (filesystem) or "s3" (MinIO/S3)
STORAGE_BACKEND=s3

# Local filesystem storage root (used when STORAGE_BACKEND=local)
STORAGE_ROOT=/data/objects

# ─────────────────────────────────────────────────────────────────
# JWT Authentication Configuration
# ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=R3vOlv3R_S3cur3_JWT_S3cr3t_K3y_Th4t_Is_V3ry_L0ng_And_Complex_1234567890
JWT_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_DAYS=30

# ─────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173
